# CuratorX QA sidecar — copy to `.env.qa` (gitignored) and fill placeholders.
# Do NOT commit real passwords. Do NOT reuse production secrets or /config.

# --- Compose / host ---
QA_IMAGE=romwil/curatorx:latest
QA_HOST_PORT=8790
# Unraid / automat example:
# QA_CONFIG_PATH=/mnt/user/appdata/curatorx-qa
QA_CONFIG_PATH=./config-qa

# Required for multi-user session cookies
CURATORX_SESSION_SECRET=replace-with-openssl-rand-hex-32

# Guest tour (public /tour) — env wins over settings.json when set
CURATORX_GUEST_TOUR_ENABLED=1

# Seed script personas (passwords ≥ 8 chars). Placeholders only.
QA_OWNER_USER=qa-owner
QA_OWNER_PASSWORD=change-me-owner-password
QA_MEMBER_USER=qa-member
QA_MEMBER_PASSWORD=change-me-member-password
QA_YOUTH_USER=qa-youth
QA_YOUTH_PASSWORD=change-me-youth-password
# Optional logged-in guest *role* (guest shell). Public /tour needs no account.
QA_GUEST_USER=qa-guest
QA_GUEST_PASSWORD=change-me-guest-password
QA_SEED_GUEST_ROLE=1

# Base URL for seed / Playwright / Cursor browser MCP (automat LAN)
QA_BASE_URL=http://10.10.1.202:8790

# Optional LLM / library (auth QA works without these)
# LLM_PROVIDER=openai_compatible
# LLM_BASE_URL=
# LLM_API_KEY=
# LLM_MODEL=gpt-4o-mini
# PLEX_URL=
# PLEX_TOKEN=
