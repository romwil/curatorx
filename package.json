{
  "name": "curatorx",
  "private": true,
  "version": "1.17.1",
  "scripts": {
    "test": "python -m pytest && npm run test:frontend && npm run test:e2e",
    "test:frontend": "cd frontend && npm install && npm run test:unit && npm run build",
    "test:e2e": "playwright test",
    "test:e2e:live": "E2E_MOCK_APIS=0 playwright test",
    "test:e2e:live-stack": "CURATORX_E2E_LIVE=1 E2E_MOCK_APIS=0 playwright test e2e/live.spec.ts",
    "test:e2e:ui": "playwright test --ui"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1"
  }
}
