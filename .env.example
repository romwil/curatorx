# CuratorX local/dev environment
DATA_DIR=./config
PORT=8788
PLEX_URL=
PLEX_TOKEN=
PLEX_MOVIE_SECTION=
PLEX_TV_SECTION=
RADARR_URL=
RADARR_API_KEY=
SONARR_URL=
SONARR_API_KEY=
MOVIES_ROOT=/media/movies
TV_ROOT=/media/tv
TMDB_API_KEY=
TVDB_API_KEY=
FANART_API_KEY=
TAUTULLI_URL=
TAUTULLI_API_KEY=
LLM_PROVIDER=openai_compatible
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_EMBEDDING_MODEL=text-embedding-3-small

# Optional Seerr (Jellyseerr / Overseerr) — used by live integration tests
# SEERR_URL=
# SEERR_API_KEY=

# Optional shared secret for POST /api/webhooks/plex (header: X-CuratorX-Webhook-Secret)
# CURATORX_WEBHOOK_SECRET=

# Optional dual-mode HTTP MCP at /mcp (or generate / rotate in Admin → Advanced)
# CURATORX_MCP_API_KEY=           # privacy: public schema, read-only
# CURATORX_MCP_FULL_API_KEY=      # full: must differ from privacy key
# Stdio full mode: CURATORX_MCP_MODE=full (also needs distinct FULL key)
# TMDB CDN sizes for MCP / privacy posters (also settings.json / Admin → Advanced):
# mcp_tmdb_poster_size=w500       # w185 | w342 | w500 | w780
# mcp_tmdb_backdrop_size=w1280    # w300 | w780 | w1280 | original

# Opt-in live suites (see docs/TESTING.md)
# CURATORX_LIVE_INTEGRATION=1
# CURATORX_E2E_LIVE=1


# Logging (stdout/stderr — use `docker compose logs -f curatorx`)
# CURATORX_LOG_LEVEL=INFO
# LOG_LEVEL=INFO
# LOG_FORMAT=text
