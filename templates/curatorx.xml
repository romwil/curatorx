<?xml version="1.0"?>
<!-- Canonical Unraid template -->
<Container version="2">
  <Name>curatorx</Name>
  <Repository>romwil/curatorx:1.3</Repository>
  <Registry>https://hub.docker.com/r/romwil/curatorx</Registry>
  <Network>bridge</Network>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/romwil/curatorx/issues</Support>
  <Project>https://github.com/romwil/curatorx</Project>
  <Icon>https://raw.githubusercontent.com/romwil/curatorx/main/unraid/curatorx-icon.png</Icon>
  <Overview>
Chat-first Plex collection curator with BYOP LLM support, RAG over your library, TMDB discovery, and confirmation-gated Radarr/Sonarr add/remove actions.
  </Overview>
  <Description>
CuratorX helps you curate your movie and TV collection through conversation. Connect Plex, Radarr, Sonarr, TMDB, and your preferred LLM provider.

**First run**
1. Open the Web UI at port **8788**.
2. Complete setup in **Settings** (`/config`).
3. Run **Sync library** to index your Plex libraries.
4. Start chatting with the curator.

**Optional:** Tautulli for watch stats and purge suggestions; Fanart.tv for richer poster art.

**Support:** [GitHub Issues](https://github.com/romwil/curatorx/issues)
  </Description>
  <Category>MediaServer:Other Tools:Utilities</Category>
  <WebUI>http://[IP]:[PORT:8788]/</WebUI>
  <TemplateURL>https://raw.githubusercontent.com/romwil/curatorx/main/templates/curatorx.xml</TemplateURL>
  <Config Name="Web UI port" Target="8788" Default="8788" Mode="tcp" Description="CuratorX web interface" Type="Port" Display="always" Required="true" Mask="false">8788</Config>
  <Config Name="Config" Target="/config" Default="/mnt/user/appdata/curatorx/config" Mode="rw" Description="settings.json and SQLite database" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/curatorx/config</Config>
  <Config Name="TZ" Target="TZ" Default="UTC" Mode="" Description="Container timezone for preferred library sync hour (e.g. America/New_York)" Type="Variable" Display="advanced" Required="false" Mask="false">UTC</Config>
  <Config Name="PLEX_URL" Target="PLEX_URL" Default="" Mode="" Description="Optional seed: Plex URL" Type="Variable" Display="advanced" Required="false" Mask="false"/>
  <Config Name="PLEX_TOKEN" Target="PLEX_TOKEN" Default="" Mode="" Description="Optional seed: Plex Media Server token (library access; not household Sign in with Plex)" Type="Variable" Display="advanced" Required="false" Mask="true"/>
  <Config Name="RADARR_URL" Target="RADARR_URL" Default="" Mode="" Description="Optional seed: Radarr URL" Type="Variable" Display="advanced" Required="false" Mask="false"/>
  <Config Name="RADARR_API_KEY" Target="RADARR_API_KEY" Default="" Mode="" Description="Optional seed: Radarr API key" Type="Variable" Display="advanced" Required="false" Mask="true"/>
  <Config Name="SONARR_URL" Target="SONARR_URL" Default="" Mode="" Description="Optional seed: Sonarr URL" Type="Variable" Display="advanced" Required="false" Mask="false"/>
  <Config Name="SONARR_API_KEY" Target="SONARR_API_KEY" Default="" Mode="" Description="Optional seed: Sonarr API key" Type="Variable" Display="advanced" Required="false" Mask="true"/>
  <Config Name="TMDB_API_KEY" Target="TMDB_API_KEY" Default="" Mode="" Description="Optional seed: TMDB API key" Type="Variable" Display="advanced" Required="false" Mask="true"/>
  <Config Name="LLM_API_KEY" Target="LLM_API_KEY" Default="" Mode="" Description="Optional seed: LLM API key" Type="Variable" Display="advanced" Required="false" Mask="true"/>
  <Config Name="LLM_PROVIDER" Target="LLM_PROVIDER" Default="openai_compatible" Mode="" Description="LLM provider: openai_compatible, anthropic, ollama" Type="Variable" Display="advanced" Required="false" Mask="false">openai_compatible</Config>
  <Config Name="CURATORX_SESSION_SECRET" Target="CURATORX_SESSION_SECRET" Default="" Mode="" Description="Optional: strong secret for multi-user session cookies (auto-generated under Config if unset)" Type="Variable" Display="advanced" Required="false" Mask="true"/>
  <Config Name="CURATORX_WEBHOOK_SECRET" Target="CURATORX_WEBHOOK_SECRET" Default="" Mode="" Description="Required for Plex webhook auth (X-CuratorX-Webhook-Secret)" Type="Variable" Display="advanced" Required="false" Mask="true"/>
  <Config Name="CURATORX_MCP_API_KEY" Target="CURATORX_MCP_API_KEY" Default="" Mode="" Description="Privacy MCP key for HTTP /mcp (public schema, read-only). Or generate in Admin → Advanced." Type="Variable" Display="advanced" Required="false" Mask="true"/>
  <Config Name="CURATORX_MCP_FULL_API_KEY" Target="CURATORX_MCP_FULL_API_KEY" Default="" Mode="" Description="Full MCP key for trusted in-stack /mcp (must differ from privacy key). Or generate in Admin → Advanced." Type="Variable" Display="advanced" Required="false" Mask="true"/>
</Container>
