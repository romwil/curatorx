<?xml version="1.0"?>
<Container version="2">
  <Name>mediacurator</Name>
  <Repository>romwil/mediacurator:latest</Repository>
  <Registry>https://hub.docker.com/r/romwil/mediacurator</Registry>
  <Network>bridge</Network>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/romwil/mediacurator/issues</Support>
  <Project>https://github.com/romwil/mediacurator</Project>
  <Overview>
Chat-first Plex collection curator with BYOP LLM support, RAG over your library, TMDB discovery, and confirmation-gated Radarr/Sonarr add/remove actions.
  </Overview>
  <Description>
MediaCurator helps you curate your movie and TV collection through conversation. Connect Plex, Radarr, Sonarr, TMDB, and your preferred LLM provider.

**First run**
1. Open the Web UI at port **8788**.
2. Complete setup in **Settings** (`/config`).
3. Run **Sync library** to index your Plex libraries.
4. Start chatting with the curator.

**Optional:** Tautulli for watch stats and purge suggestions; Fanart.tv for richer poster art.

**Support:** [GitHub Issues](https://github.com/romwil/mediacurator/issues)
  </Description>
  <Category>MediaServer:Other Tools:Utilities</Category>
  <WebUI>http://[IP]:[PORT:8788]/</WebUI>
  <TemplateURL>https://raw.githubusercontent.com/romwil/mediacurator/main/templates/mediacurator.xml</TemplateURL>
  <Config Name="Web UI port" Target="8788" Default="8788" Mode="tcp" Description="MediaCurator web interface" Type="Port" Display="always" Required="true" Mask="false">8788</Config>
  <Config Name="Config" Target="/config" Default="/mnt/user/appdata/mediacurator/config" Mode="rw" Description="settings.json and SQLite database" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/mediacurator/config</Config>
  <Config Name="PLEX_URL" Target="PLEX_URL" Default="" Mode="" Description="Optional seed: Plex URL" Type="Variable" Display="advanced" Required="false" Mask="false"/>
  <Config Name="PLEX_TOKEN" Target="PLEX_TOKEN" Default="" Mode="" Description="Optional seed: Plex token" Type="Variable" Display="advanced" Required="false" Mask="true"/>
  <Config Name="RADARR_URL" Target="RADARR_URL" Default="" Mode="" Description="Optional seed: Radarr URL" Type="Variable" Display="advanced" Required="false" Mask="false"/>
  <Config Name="RADARR_API_KEY" Target="RADARR_API_KEY" Default="" Mode="" Description="Optional seed: Radarr API key" Type="Variable" Display="advanced" Required="false" Mask="true"/>
  <Config Name="SONARR_URL" Target="SONARR_URL" Default="" Mode="" Description="Optional seed: Sonarr URL" Type="Variable" Display="advanced" Required="false" Mask="false"/>
  <Config Name="SONARR_API_KEY" Target="SONARR_API_KEY" Default="" Mode="" Description="Optional seed: Sonarr API key" Type="Variable" Display="advanced" Required="false" Mask="true"/>
  <Config Name="TMDB_API_KEY" Target="TMDB_API_KEY" Default="" Mode="" Description="Optional seed: TMDB API key" Type="Variable" Display="advanced" Required="false" Mask="true"/>
  <Config Name="LLM_API_KEY" Target="LLM_API_KEY" Default="" Mode="" Description="Optional seed: LLM API key" Type="Variable" Display="advanced" Required="false" Mask="true"/>
  <Config Name="LLM_PROVIDER" Target="LLM_PROVIDER" Default="openai_compatible" Mode="" Description="LLM provider: openai_compatible, anthropic, ollama" Type="Variable" Display="advanced" Required="false" Mask="false">openai_compatible</Config>
</Container>
